# PathCouncil — environment variables
#
# All user data is encrypted in the browser (IndexedDB). No database required.
#
# API keys: two modes are supported.
#   1. Server key — set a key below. Users skip key entry; the server key is used for all LLM calls.
#   2. BYOK — leave all keys blank. Users enter their own key in the Setup screen;
#              it is encrypted via the vault and stored only in their local IndexedDB.
#
# You only need to set the key for the provider(s) you want to support.

# ── Provider API keys (server key mode) ──────────────────────────────────────

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...
# MISTRAL_API_KEY=...
# GROQ_API_KEY=...

# ── Provider base URLs ────────────────────────────────────────────────────────
# Required for each provider you enable. Set to the provider's API endpoint,
# a proxy, or a local model server (e.g. Ollama).

# ANTHROPIC_BASE_URL=
# OPENAI_BASE_URL=
# GOOGLE_BASE_URL=
# MISTRAL_BASE_URL=
# GROQ_BASE_URL=

# ── App ───────────────────────────────────────────────────────────────────────

# Base URL — used by API routes for self-referencing links.
# Leave blank for local development (defaults to http://localhost:3000).
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
